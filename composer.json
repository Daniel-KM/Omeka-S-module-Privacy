{
    "name": "daniel-km/omeka-s-module-privacy",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Add a HTTP header to the site to invite Google not to track visitors via Chrome and derivative browsers",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "private life",
        "gdpr",
        "google",
        "chrome"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-Privacy",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-Privacy/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2432)": {
        "omeka/omeka-s": "^1.0 || ^2.0 || ^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Privacy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrivacyTest\\": "tests/PrivacyTest/"
        }
    },
    "extra": {
        "installer-name": "Privacy"
    }
}
